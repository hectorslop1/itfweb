---
import Button from './Button.astro';
import { ctas, navigation } from '../data/navigation';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 border-b border-white/55 bg-[rgba(247,243,234,0.72)] backdrop-blur-2xl">
  <div class="site-shell flex items-center justify-between gap-5 py-4">
    <a href="/" class="flex min-w-0 items-center gap-3.5 transition hover:opacity-95" aria-label="Ives Torres Foundation home">
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-[1.15rem] bg-[linear-gradient(145deg,#17385e_0%,#2b5a86_100%)] text-sm font-bold text-white shadow-soft">
        ITF
      </span>
      <span class="flex min-w-0 flex-col leading-tight">
        <span class="truncate font-display text-[1.02rem] text-ink sm:text-lg">Ives Torres Foundation</span>
        <span class="truncate text-[0.68rem] uppercase tracking-[0.24em] text-muted sm:text-[0.72rem]">Apoyo, recursos y comunidad</span>
      </span>
    </a>

    <nav class="hidden items-center gap-2 xl:gap-3 lg:flex" aria-label="Primary">
      {navigation.map((item) => {
        const isActive = pathname === item.href;
        return (
        <a
          href={item.href}
          aria-current={isActive ? 'page' : undefined}
          class:list={[
            'rounded-full px-4 py-2.5 text-sm font-medium transition duration-300',
            isActive ? 'bg-white text-navy shadow-sm ring-1 ring-white/80' : 'text-muted hover:bg-white/70 hover:text-navy',
          ]}
        >
          {item.label}
        </a>
      )})}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      {ctas.map((item) => (
        <Button href={item.href} variant={item.variant as 'primary' | 'secondary'}>
          {item.label}
        </Button>
      ))}
    </div>

    <details class="group relative lg:hidden">
      <summary class="list-none rounded-full border border-line bg-white/92 px-4 py-2.5 text-sm font-semibold text-navy shadow-sm transition hover:bg-white">
        Menú
      </summary>
      <div class="absolute right-0 mt-3 w-[min(20rem,calc(100vw-2rem))] rounded-3xl border border-line bg-white/95 p-4 shadow-[0_22px_60px_rgba(16,35,62,0.18)] backdrop-blur-xl">
        <nav class="flex flex-col gap-2" aria-label="Mobile">
          {navigation.map((item) => (
            <a
              href={item.href}
              class="rounded-2xl px-3 py-3 text-sm font-medium text-muted transition hover:bg-panel hover:text-navy"
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="mt-4 flex flex-col gap-2">
          {ctas.map((item) => (
            <Button href={item.href} variant={item.variant as 'primary' | 'secondary'} class="w-full">
              {item.label}
            </Button>
          ))}
        </div>
      </div>
    </details>
  </div>
</header>
