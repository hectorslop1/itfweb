---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { aboutHighlights, aboutSections, partners, values } from '../data/site';
---

<BaseLayout
  title="About | Ives Torres Foundation"
  description="Conoce la misión, visión y objetivo de Ives Torres Foundation."
>
  <PageHero
    eyebrow="Nosotros"
    title="Una fundación fundada en 2019 para crear más oportunidades para personas con discapacidad y sus familias."
    description="Ives Torres Foundation acompaña a familias hispanas con recursos, educación, autoabogacía, eventos y redes de apoyo."
    imageSrc="/images/donate/donate-support.jpg"
    imageAlt="Integrantes de la comunidad en una actividad de la fundación"
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {aboutSections.map((item) => (
        <article class="premium-card p-6" data-reveal>
          <h2 class="font-display text-2xl text-ink">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="section-band section-band-warm grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-center" data-reveal>
      <div>
        <SectionHeading
          eyebrow="Valores"
          title="El trabajo de ITF se mueve con inclusión, equidad y comunidad."
          description="Estos principios aparecen en la manera en que la fundación comparte educación, promueve participación y construye redes de apoyo."
        />
      </div>
      <div class="flex flex-wrap gap-3">
        {values.map((value) => (
          <span class="rounded-full border border-line bg-panel px-4 py-2 text-sm font-medium text-navy shadow-sm">
            {value}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Historia y comunidad"
      title="La historia de ITF se entiende desde su comunidad, su presencia pública y sus alianzas."
      description="La fundación crece con acompañamiento familiar, recursos compartidos y una red amplia de aliados."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {aboutHighlights.map((item) => (
        <article class="premium-card p-6" data-reveal>
          <p class="text-sm leading-7 text-muted">{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Alianzas"
      title="Aliados que acompañan la historia reciente de la fundación."
      description="Organizaciones, escuelas y colaboradores que ayudan a ampliar recursos, oportunidades y comunidad."
    />
    <div class="mt-8 flex flex-wrap gap-3">
      {partners.map((partner) => (
        <span class="rounded-full border border-line bg-white px-4 py-2 text-sm font-medium text-muted shadow-sm" data-reveal>
          {partner}
        </span>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 pt-8 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Conversemos sobre cómo podemos apoyar a tu familia.</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Si buscas orientación, recursos o información sobre programas y eventos, estamos listos para escucharte.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Contactar a ITF</Button>
      </div>
    </div>
  </section>
</BaseLayout>
