---
import Button from './Button.astro';
import Icon from './Icon.astro';
import { ctas, navigation } from '../data/navigation';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header sticky top-0 z-40 border-b border-white/55 bg-[rgba(247,243,234,0.78)] backdrop-blur-2xl" data-site-header>
  <div class="site-shell flex items-center justify-between gap-6 py-4 lg:gap-8">
    <a href="/" class="flex min-w-0 items-center gap-4 transition hover:opacity-95" aria-label="Ives Torres Foundation home">
      <span class="grid h-[3.25rem] w-[3.25rem] shrink-0 place-items-center rounded-[1.2rem] bg-[linear-gradient(145deg,#17385e_0%,#2b5a86_100%)] text-sm font-bold text-white shadow-soft">
        ITF
      </span>
      <span class="flex min-w-0 flex-col leading-tight">
        <span class="font-display text-[1.02rem] text-ink sm:text-lg">Ives Torres Foundation</span>
        <span class="hidden text-[0.68rem] uppercase tracking-[0.24em] text-muted xl:block">Apoyo, recursos y comunidad</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 xl:gap-2 lg:flex" aria-label="Primary">
      {navigation.map((item) => {
        const isActive = pathname === item.href;
        return (
        <a
          href={item.href}
          aria-current={isActive ? 'page' : undefined}
          class:list={[
            'relative rounded-full px-4 py-2.5 text-sm font-medium transition duration-300',
            isActive
              ? 'bg-white text-navy shadow-sm ring-1 ring-white/80 after:absolute after:bottom-[0.45rem] after:left-1/2 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-gold'
              : 'text-muted hover:bg-white/72 hover:text-navy',
          ]}
        >
          {item.label}
        </a>
      )})}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      {ctas.map((item) => (
        <Button href={item.href} variant={item.variant as 'primary' | 'secondary'}>
          {item.label}
        </Button>
      ))}
    </div>

    <details class="group relative lg:hidden">
      <summary class="inline-flex list-none items-center gap-2 rounded-full border border-line bg-white/92 px-4 py-2.5 text-sm font-semibold text-navy shadow-sm transition hover:bg-white">
        <Icon name="menu" class="h-4 w-4" />
        <span>Menú</span>
      </summary>
      <div class="mobile-menu-panel absolute right-0 mt-3 w-[min(22rem,calc(100vw-2rem))] rounded-[1.9rem] border border-line bg-white/96 p-4 shadow-[0_22px_60px_rgba(16,35,62,0.18)] backdrop-blur-xl">
        <nav class="flex flex-col gap-2" aria-label="Mobile">
          {navigation.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-2xl px-3 py-3 text-sm font-medium transition',
                pathname === item.href ? 'bg-panel text-navy' : 'text-muted hover:bg-panel hover:text-navy',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="mt-4 flex flex-col gap-2">
          {ctas.map((item) => (
            <Button href={item.href} variant={item.variant as 'primary' | 'secondary'} class="w-full">
              {item.label}
            </Button>
          ))}
        </div>
        <div class="mt-5 rounded-[1.5rem] border border-line/70 bg-panel/70 p-4 text-sm text-muted">
          <div class="flex items-center gap-3">
            <Icon name="mail" class="h-4 w-4 text-navy" />
            <span>Info@IvesTorres.org</span>
          </div>
          <div class="mt-3 flex items-center gap-3">
            <Icon name="phone" class="h-4 w-4 text-navy" />
            <span>(951) 737-0951</span>
          </div>
        </div>
      </div>
    </details>
  </div>
</header>
