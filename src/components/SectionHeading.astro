---
const {
  eyebrow,
  title,
  description,
  align = 'left',
} = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
};

const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---

<div class={`flex max-w-3xl flex-col gap-3 ${alignClass}`}>
  {eyebrow && (
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold">
      {eyebrow}
    </p>
  )}
  <h2 class="font-display text-3xl tracking-tight text-ink sm:text-4xl">
    {title}
  </h2>
  {description && <p class="max-w-2xl text-base leading-7 text-muted">{description}</p>}
</div>
