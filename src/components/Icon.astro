};

const iconMarkup = icons[name];
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  class={className}
  aria-hidden={title ? undefined : 'true'}
  role={title ? 'img' : 'presentation'}
>
  {title && <title>{title}</title>}
  <Fragment set:html={iconMarkup} />
</svg>
