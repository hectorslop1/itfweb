---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { upcomingEvents } from '../data/events';
---

<BaseLayout
  title="Events | Ives Torres Foundation"
  description="See upcoming events, workshops, and community gatherings."
>
  <PageHero
    eyebrow="Events"
    title="Events that feel welcoming, clear, and community-centered."
    description="This page uses placeholder event data to keep the future event experience simple and approachable."
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-4">
      {upcomingEvents.map((event) => (
        <article class="flex flex-col gap-5 rounded-[1.5rem] border border-white/80 bg-white p-5 shadow-soft sm:flex-row sm:items-center">
          <div class="grid h-20 w-20 shrink-0 place-items-center rounded-2xl bg-panel text-center">
            <span class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{event.date}</span>
          </div>
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
              <h2 class="font-display text-xl text-ink">{event.title}</h2>
              <span class="rounded-full bg-sky/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-navy">
                {event.location}
              </span>
            </div>
            <p class="mt-2 text-sm leading-6 text-muted">{event.details}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Event types"
      title="A quick way to understand the kinds of gatherings the foundation hosts."
      description="Future CMS content can sort events by region, format, language, and audience."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="rounded-[1.5rem] bg-white p-6 shadow-soft ring-1 ring-line">
        <h2 class="font-display text-xl text-ink">Workshops</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Learning-focused sessions for practical family support.</p>
      </article>
      <article class="rounded-[1.5rem] bg-white p-6 shadow-soft ring-1 ring-line">
        <h2 class="font-display text-xl text-ink">Community events</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Gatherings centered on connection and shared resources.</p>
      </article>
      <article class="rounded-[1.5rem] bg-white p-6 shadow-soft ring-1 ring-line">
        <h2 class="font-display text-xl text-ink">Resource fairs</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Partner-supported events with local information and guidance.</p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Want event updates later?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        The next step will be adding CMS-driven event detail pages and links for registration or more information.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Ask about events</Button>
      </div>
    </div>
  </section>
</BaseLayout>
