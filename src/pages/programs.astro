---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { featuredPrograms } from '../data/programs';
---

<BaseLayout
  title="Programs | Ives Torres Foundation"
  description="Explora los programas y espacios de apoyo de Ives Torres Foundation."
>
  <PageHero
    eyebrow="Programas"
    title="Programas y recursos que fortalecen a familias hispanas y a personas con discapacidad."
    description="La misión de ITF incluye educación especial, Centros Regionales, autoabogacía, actividades, eventos e inclusión."
    imageSrc="/images/hero-family.svg"
    imageAlt="Ilustracion de familias y apoyo comunitario"
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-5 lg:grid-cols-3">
      {featuredPrograms.map((program) => (
        <article class="shell-card p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{program.label}</p>
          <h2 class="mt-3 font-display text-2xl text-ink">{program.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{program.description}</p>
          <p class="mt-5 text-sm font-medium text-navy">{program.audience}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Como se vive"
      title="Los programas combinan aprendizaje, defensa y comunidad."
      description="Padres con Poder, educación y presencia comunitaria reflejan el corazón público de la fundación."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <article class="shell-panel p-6">
        <h2 class="font-display text-xl text-ink">Lo que encuentran las familias</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Recursos para educación especial, eventos comunitarios y espacios donde otras familias entienden el proceso.
        </p>
      </article>
      <article class="shell-card p-6">
        <h2 class="font-display text-xl text-ink">Lo que nos importa</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Que cada familia salga con más claridad, herramientas de autoabogacía y la sensación de que no está sola.
        </p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 pt-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">No sabes por donde empezar?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Podemos ayudarte a identificar el recurso, evento o programa que mejor se ajusta a las necesidades de tu familia.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Pedir orientacion</Button>
      </div>
    </div>
  </section>
</BaseLayout>
