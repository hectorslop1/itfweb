---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { resourceTopics } from '../data/resources';
---

<BaseLayout
  title="Recursos | Ives Torres Foundation"
  description="Recursos y guías para familias que buscan información clara y apoyo práctico."
>
  <PageHero
    eyebrow="Recursos"
    title="Recursos para ayudar a nuestras familias a lograr más."
    description="Categorías, materiales y notas para apoyar a familias hispanas con información más clara y accesible."
    imageSrc="/images/community/community-cabe.jpeg"
    imageAlt="Comunidad reunida en una actividad educativa"
  />

  <section class="site-shell py-12">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {resourceTopics.map((topic) => (
        <article class="premium-card p-5" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{topic.title}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{topic.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell py-6">
    <SectionHeading
      eyebrow="Cómo ayudan"
      title="Los recursos ayudan a prepararse, hacer mejores preguntas y participar con más confianza."
      description="El trabajo público de la fundación mezcla educación, familia, programas, Padres con Poder y presencia en Valle Central."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <article class="shell-panel p-6" data-reveal>
        <h2 class="font-display text-xl text-ink">Lenguaje claro</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Explicaciones sencillas para navegar decisiones importantes sin sentirse abrumados.
        </p>
      </article>
      <article class="premium-card p-6" data-reveal>
        <h2 class="font-display text-xl text-ink">Apoyo bilingüe</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Materiales que respetan el contexto lingüístico y cultural de las familias hispanas.
        </p>
      </article>
    </div>
  </section>

  <section class="site-shell pb-16 pt-12">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">¿Buscas un recurso en particular?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Nuestro equipo puede orientarte hacia materiales, notas o recursos útiles según la etapa en la que se encuentre tu familia.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Solicitar orientación</Button>
      </div>
    </div>
  </section>
</BaseLayout>
