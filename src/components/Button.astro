---
type Variant = 'primary' | 'secondary' | 'ghost';

const {
  href,
  variant = 'primary',
  class: className = '',
  ...rest
} = Astro.props as {
  href?: string;
  variant?: Variant;
  class?: string;
  [key: string]: unknown;
};

const base =
  'inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold transition duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/60 focus-visible:ring-offset-2 focus-visible:ring-offset-bg';

const variants: Record<Variant, string> = {
  primary:
    'bg-navy text-white shadow-soft hover:-translate-y-0.5 hover:bg-[#0f2747]',
  secondary:
    'bg-white text-navy ring-1 ring-inset ring-line hover:-translate-y-0.5 hover:bg-panel',
  ghost: 'text-navy hover:bg-white/70 hover:text-[#0f2747]',
};

const classes = `${base} ${variants[variant]} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button class={classes} {...rest}>
    <slot />
  </button>
)}
