---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { resourceTopics } from '../data/resources';
---

<BaseLayout
  title="Resources | Ives Torres Foundation"
  description="Browse placeholder resource categories for families and supporters."
>
  <PageHero
    eyebrow="Resources"
    title="A resource hub built for fast scanning and future growth."
    description="This page keeps the category structure clear so families can find the right starting point quickly."
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {resourceTopics.map((topic) => (
        <article class="rounded-[1.5rem] border border-white/80 bg-white p-5 shadow-soft">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{topic.title}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{topic.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Resource types"
      title="The future library can include guides, videos, PDFs, and links."
      description="This lightweight structure is a placeholder for CMS-managed resources later."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <article class="rounded-[1.5rem] bg-panel p-6">
        <h2 class="font-display text-xl text-ink">Family-first language</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Plain-language summaries will help families understand what each resource is for before they open it.
        </p>
      </article>
      <article class="rounded-[1.5rem] bg-white p-6 shadow-soft ring-1 ring-line">
        <h2 class="font-display text-xl text-ink">Bilingual organization</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Future filters can sort by language, category, and format without overwhelming the page.
        </p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Need help finding the right resource?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        The contact page will eventually route people to support, partnerships, and direct guidance.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Get in touch</Button>
      </div>
    </div>
  </section>
</BaseLayout>
