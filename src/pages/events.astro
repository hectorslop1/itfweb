---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { upcomingEvents } from '../data/events';
---

<BaseLayout
  title="Eventos | Ives Torres Foundation"
  description="Conoce próximos eventos, talleres y encuentros comunitarios."
>
  <PageHero
    eyebrow="Eventos"
    title="Eventos pensados para aprender, compartir y fortalecer comunidad."
    description="Los eventos públicos de ITF acercan recursos, conversación, inclusión y apoyo a familias de Inland Empire, Valle Central y otras comunidades."
    imageSrc="/images/events/event-expo.jpg"
    imageAlt="Flyer y materiales de un evento comunitario"
    imagePosition="center 56%"
    imageNote="Los detalles de cada encuentro se comparten en coordinación con la fundación."
    imageNoteIcon="calendar"
  />

  <section class="site-shell py-12" id="eventos" data-reveal-group>
    <div class="grid gap-5 lg:grid-cols-3">
      {upcomingEvents.map((event) => (
        <article class="premium-card flex h-full flex-col overflow-hidden" data-reveal>
          <div class="media-frame h-52 rounded-b-none border-0">
            {event.image.includes('expo') ? (
              <img
                src={event.image}
                alt={event.title}
                loading="lazy"
                class="h-full w-full bg-white object-contain p-5"
              />
            ) : (
              <img
                src={event.image}
                alt={event.title}
                loading="lazy"
                class="h-full w-full object-cover"
                style={event.image.includes('community-cabe') ? 'object-position: center 35%;' : 'object-position: center;'}
              />
            )}
          </div>
          <div class="flex min-h-[18rem] grow flex-col p-6">
            <div class="mb-4 flex items-center justify-between gap-3">
              <div class="inline-flex items-center rounded-2xl bg-panel px-4 py-2 shadow-sm">
                <span class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{event.date}</span>
              </div>
              <span class="soft-icon-chip h-10 w-10">
                <Icon name="calendar" class="h-4 w-4" />
              </span>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="tag-badge !border-transparent !bg-sky/70">{event.region}</span>
              {event.time && (
                <span class="tag-badge !border-transparent" style="background-color: rgba(220, 163, 56, 0.16);">
                  {event.time}
                </span>
              )}
            </div>
            <h2 class="mt-4 font-display text-2xl text-ink">{event.title}</h2>
            <p class="mt-3 grow text-sm leading-7 text-muted">{event.details}</p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <Button href={event.ctaLabel === 'Registrarme' ? '#registro-eventos' : '#detalles-eventos'} variant={event.ctaLabel === 'Registrarme' ? 'primary' : 'secondary'}>
                {event.ctaLabel}
              </Button>
              {event.ctaLabel === 'Registrarme' ? (
                <span class="tag-badge !border-line !bg-white">Registro</span>
              ) : (
                <span class="tag-badge !border-line !bg-white">Detalles</span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell py-6" id="detalles-eventos">
    <SectionHeading
      eyebrow="Experiencia"
      title="Más que fechas, los eventos son una puerta de entrada a la comunidad."
      description="Cafecitos, talleres y encuentros que combinan aprendizaje, celebración y acompañamiento."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="premium-card p-6" data-reveal>
        <span class="soft-icon-chip">
          <Icon name="calendar" class="h-5 w-5" />
        </span>
        <h2 class="font-display text-xl text-ink">Talleres</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Espacios de aprendizaje con explicaciones claras y tiempo para preguntas reales.</p>
      </article>
      <article class="premium-card p-6" data-reveal>
        <span class="soft-icon-chip">
          <Icon name="users" class="h-5 w-5" />
        </span>
        <h2 class="font-display text-xl text-ink">Convivencia</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Encuentros que fortalecen relaciones, confianza y apoyo entre familias.</p>
      </article>
      <article class="premium-card p-6" data-reveal>
        <span class="soft-icon-chip">
          <Icon name="book" class="h-5 w-5" />
        </span>
        <h2 class="font-display text-xl text-ink">Recursos</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Oportunidades para conocer aliados, materiales útiles y servicios disponibles.</p>
      </article>
    </div>
  </section>

  <section class="site-shell py-6" id="registro-eventos">
    <div class="section-band section-band-soft grid gap-6 lg:grid-cols-[0.94fr_1.06fr] lg:items-center" data-reveal>
      <div>
        <div class="eyebrow-chip">
          <Icon name="calendar" class="h-4 w-4" />
          <span>Registro de eventos</span>
        </div>
        <h2 class="mt-5 font-display text-3xl tracking-tight text-ink">Los detalles de registro se confirmarán con la fundación antes del lanzamiento.</h2>
      </div>
      <p class="text-sm leading-7 text-muted">
        Esta sección reúne la información principal de cada encuentro para que las familias puedan ubicar fechas, región y tipo de experiencia de una manera más clara.
      </p>
    </div>
  </section>

  <section class="site-shell pb-16 pt-12">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">¿Quieres saber qué evento puede ser mejor para tu familia?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Podemos ayudarte a encontrar un taller, encuentro o actividad que responda a tus intereses y necesidades.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Pedir información</Button>
      </div>
    </div>
  </section>
</BaseLayout>
