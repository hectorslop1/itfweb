---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import ContactFormDemo from '../components/ContactFormDemo.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { contactPoints, contactReasons } from '../data/site';
---

<BaseLayout
  title="Contact | Ives Torres Foundation"
  description="Contacta a Ives Torres Foundation para recibir apoyo, colaborar o hacer una consulta."
>
  <PageHero
    eyebrow="Contacto"
    title="Estamos aqui para escuchar, orientar y conectar a tu familia con apoyo."
    description="Si necesitas informacion, quieres colaborar o buscas un recurso, puedes escribirnos y con gusto te responderemos."
    imageSrc="/images/hero-family.svg"
    imageAlt="Ilustracion de apoyo comunitario y familias"
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-5 md:grid-cols-3">
      {contactPoints.map((point) => (
        <article class="shell-card p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{point.label}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{point.value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Como podemos ayudarte"
      title="Elige el motivo de tu mensaje y cuentanos que necesitas."
      description="Queremos que pedir apoyo, hacer una pregunta o iniciar una colaboracion se sienta facil y claro."
    />
    <div class="mt-8 flex flex-wrap gap-3">
      {contactReasons.map((reason) => (
        <span class="rounded-full border border-line bg-white px-4 py-2 text-sm font-medium text-muted shadow-sm">
          {reason}
        </span>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <ContactFormDemo />
      <div class="space-y-5">
        <article class="shell-panel p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">Apoyo familiar</p>
          <h2 class="mt-3 font-display text-2xl text-ink">Una conversacion puede ser el primer paso.</h2>
          <p class="mt-3 text-sm leading-7 text-muted">
            Si no sabes por donde empezar, podemos orientarte hacia recursos, programas o eventos que se alineen con tu situacion.
          </p>
        </article>
        <article class="shell-card p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">Aliados y voluntarios</p>
          <p class="mt-3 text-sm leading-7 text-muted">
            Tambien recibimos mensajes de organizaciones, voluntarios y personas que quieren apoyar el trabajo de la fundacion.
          </p>
          <div class="mt-5">
            <Button href="/donate" variant="secondary">Ver formas de apoyar</Button>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
