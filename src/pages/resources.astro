---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { resourceTopics } from '../data/resources';
---

<BaseLayout
  title="Resources | Ives Torres Foundation"
  description="Recursos y guias para familias que buscan informacion clara y apoyo practico."
>
  <PageHero
    eyebrow="Recursos"
    title="Una biblioteca pensada para responder preguntas reales de las familias."
    description="Aqui se reunen materiales, guias y orientacion para ayudar a tomar decisiones con mayor claridad y confianza."
    imageSrc="/images/resources-library.svg"
    imageAlt="Ilustracion de recursos y biblioteca"
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {resourceTopics.map((topic) => (
        <article class="shell-card p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{topic.title}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{topic.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Como ayudan"
      title="Los recursos sirven para prepararse, preguntar mejor y actuar con mas tranquilidad."
      description="Nuestro objetivo es que cada familia encuentre materiales claros, cercanos y faciles de compartir en casa."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <article class="shell-panel p-6">
        <h2 class="font-display text-xl text-ink">Lenguaje claro</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Explicaciones sencillas para navegar decisiones importantes sin sentirse abrumados.
        </p>
      </article>
      <article class="shell-card p-6">
        <h2 class="font-display text-xl text-ink">Apoyo bilingue</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Materiales que respetan el contexto linguistico y cultural de las familias hispanas.
        </p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 pt-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Buscas un recurso en particular?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Nuestro equipo puede orientarte hacia materiales y apoyos utiles segun la etapa en la que se encuentre tu familia.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Solicitar orientacion</Button>
      </div>
    </div>
  </section>
</BaseLayout>
