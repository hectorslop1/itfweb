---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { heroHighlights, heroStats } from '../data/hero';
import { featuredPrograms } from '../data/programs';
import { upcomingEvents } from '../data/events';
import { resourceTopics } from '../data/resources';
import { featuredNews } from '../data/news';
import { facebookHighlights } from '../data/facebook';
import { donationHighlights } from '../data/site';

const whatWeDo = [
  {
    title: 'Educación especial y Centros Regionales',
    icon: 'book',
    description:
      'Compartimos capacitación y recursos para que las familias puedan navegar servicios, escuela y salud con mayor claridad.',
  },
  {
    title: 'Autoabogacía e inclusión',
    icon: 'heart',
    description:
      'Promovemos herramientas, actividades y espacios de participación que fortalecen la voz de las familias y las personas con discapacidad.',
  },
  {
    title: 'Eventos y redes de apoyo',
    icon: 'users',
    description:
      'Creamos encuentros donde las familias se sienten acompañadas, conectadas y respaldadas por la comunidad.',
  },
];

const impactStats = [
  { value: '5,000+', label: 'Miembros' },
  { value: '50+', label: 'Ciudades' },
  { value: '1,000+', label: 'Familias' },
];
---

<BaseLayout
  title="Ives Torres Foundation | Más oportunidades para personas con discapacidad"
  description="Brindamos apoyo comunitario a familias y a sus seres queridos con discapacidad."
>
  <section class="hero-shell pt-12 lg:pt-16">
    <div class="section-band section-band-soft relative overflow-hidden" data-reveal>
      <div class="floating-orb absolute -left-6 top-8 h-20 w-20 rounded-full bg-gold/15 blur-2xl"></div>
      <div class="floating-orb absolute right-10 top-16 hidden h-28 w-28 rounded-full bg-sky/60 blur-3xl lg:block"></div>
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center xl:gap-14">
      <div class="flex flex-col justify-center gap-8">
        <div class="eyebrow-chip">
          <span class="kicker-dot">California · Comunidad bilingüe · Apoyo familiar</span>
        </div>

        <div class="space-y-5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold">Somos ITF</p>
          <h1 class="max-w-4xl font-display text-[clamp(2.85rem,4.8vw,4.6rem)] leading-[1.04] tracking-tight text-ink">
            Apoyamos a familias hispanas con seres queridos con discapacidad a encontrar recursos, educación y comunidad.
          </h1>
          <p class="max-w-2xl text-[1.05rem] leading-8 text-muted">
            Apoyamos a familias e individuos con discapacidades intelectuales y del desarrollo con
            educación especial, Centros Regionales, servicios de salud, herramientas de
            autoabogacía, actividades, eventos y redes de apoyo.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row">
          <Button href="/contact">Necesito apoyo</Button>
          <Button href="/events" variant="secondary">Ver eventos</Button>
          <Button href="/donate" variant="secondary">Donar</Button>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          {heroStats.map((stat) => (
            <div class="shell-card p-4" data-reveal>
              <p class="text-base font-semibold uppercase tracking-[0.2em] text-navy">{stat.value}</p>
              <p class="mt-2 text-sm leading-6 text-muted">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="grid gap-4">
        <div class="relative min-h-[23rem] overflow-hidden rounded-[2.2rem] border border-white/75 bg-white shadow-[0_28px_80px_rgba(16,35,62,0.18)]" data-reveal>
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(11,26,48,0.08)_0%,rgba(11,26,48,0.42)_100%)]"></div>
          <img
            src="/images/hero/community-hero.jpg"
            alt="Familias y comunidad reunidas en una actividad de Ives Torres Foundation"
            class="h-full w-full object-cover"
          />
          <div class="absolute inset-x-5 bottom-5 rounded-[1.5rem] border border-white/20 bg-white/14 p-4 text-white backdrop-blur-md">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/80">Comunidad en acción</p>
            <p class="mt-2 max-w-sm text-sm leading-6 text-white/90">
              Espacios cálidos para aprender, conectar y sentirse acompañados.
            </p>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-[1.05fr_0.95fr]">
          <article class="rounded-[1.9rem] bg-[linear-gradient(145deg,#14365b_0%,#214f7b_100%)] p-6 text-white shadow-[0_24px_72px_rgba(16,35,62,0.22)]" data-reveal>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/70">Noticias</p>
            <h2 class="mt-3 font-display text-2xl leading-tight">{featuredNews[0].title}</h2>
            <p class="mt-3 text-sm leading-7 text-white/80">{featuredNews[0].description}</p>
            <p class="mt-4 text-xs uppercase tracking-[0.2em] text-white/60">{featuredNews[0].date}</p>
          </article>
          <div class="grid gap-4">
            {heroHighlights.slice(0, 2).map((item) => (
              <article class="shell-card p-5" data-reveal>
                <h2 class="text-sm font-semibold text-navy">{item.title}</h2>
                <p class="mt-2 text-sm leading-6 text-muted">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>

  <section class="site-shell py-20">
    <SectionHeading
      eyebrow="Lo que hacemos"
      title="Capacitación, recursos y comunidad para que ninguna familia recorra este camino sola."
      description="El trabajo de ITF une información útil, inclusión y apoyo comunitario para familias hispanas y sus seres queridos con discapacidad."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {whatWeDo.map((item) => (
        <article class="premium-card p-6" data-reveal>
          <span class="soft-icon-chip">
            <Icon name={item.icon as 'book' | 'heart' | 'users'} class="h-5 w-5" />
          </span>
          <h3 class="font-display text-2xl text-ink">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-muted">{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell py-8">
    <div class="section-band section-band-navy grid gap-8 text-white lg:grid-cols-[0.92fr_1.08fr] lg:items-center" data-reveal>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/70">Programas destacados</p>
        <h2 class="mt-3 font-display text-4xl leading-tight">Programas que conectan aprendizaje, defensa y pertenencia.</h2>
        <p class="mt-4 text-sm leading-7 text-white/80">
          Desde Padres con Poder hasta recursos de educación y presencia en Valle Central, cada programa busca responder a necesidades reales con cercanía.
        </p>
        <div class="mt-6">
          <Button href="/programs" variant="secondary">Explorar programas</Button>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {featuredPrograms.map((program) => (
          <article class="premium-card rounded-[1.8rem] bg-white/10 text-white ring-1 ring-white/15 backdrop-blur" data-reveal>
            <div class="media-frame h-40 rounded-b-none border-0">
              <img src={program.image} alt={program.title} loading="lazy" />
            </div>
            <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">{program.label}</p>
            <h3 class="mt-3 font-display text-2xl">{program.title}</h3>
            <p class="mt-3 text-sm leading-7 text-white/80">{program.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell py-20">
    <SectionHeading
      eyebrow="Próximos eventos"
      title="Eventos y encuentros que acercan información útil, convivencia y apoyo."
      description="Cafecitos, talleres y actividades comunitarias pensadas para aprender, participar y construir confianza."
    />
    <div class="mt-10 grid gap-6 lg:grid-cols-[1fr_24rem]">
      <div class="grid gap-5">
        {upcomingEvents.map((event) => (
          <article class="premium-card grid overflow-hidden lg:grid-cols-[15rem_1fr]" data-reveal>
            <div class="media-frame h-full rounded-none border-0 border-r border-white/10">
              <img src={event.image} alt={event.title} loading="lazy" />
            </div>
            <div class="p-5">
              <div class="mb-4 inline-flex rounded-2xl bg-panel px-4 py-2 text-center shadow-sm">
                <span class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{event.date}</span>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="font-display text-2xl text-ink">{event.title}</h3>
                <span class="rounded-full bg-sky/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-navy">
                  {event.region}
                </span>
                {event.time && (
                  <span class="rounded-full bg-gold/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-navy">
                    {event.time}
                  </span>
                )}
              </div>
              <p class="mt-2 text-sm leading-7 text-muted">{event.details}</p>
              <div class="mt-4">
                <Button href={event.ctaLabel === 'Registrarme' ? '/events#registro-eventos' : '/events#detalles-eventos'} variant="secondary">{event.ctaLabel}</Button>
              </div>
            </div>
          </article>
        ))}
      </div>
      <div class="media-frame min-h-[20rem]" data-reveal>
        <img
          src="/images/events/event-expo.jpg"
          alt="Participantes y recursos en un evento comunitario de ITF"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <section class="site-shell py-20">
    <div class="section-band section-band-warm grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center" data-reveal>
      <div class="media-frame min-h-[22rem]">
        <img src="/images/impact/impact-community.jpg" alt="Comunidad de ITF reunida en un evento" class="h-full w-full object-cover" />
      </div>
      <div>
        <SectionHeading
          eyebrow="Impacto"
          title="Más oportunidades de inclusión que ayudan a vivir con mayor independencia."
          description="La fundación comparte una comunidad en crecimiento con miles de miembros, cientos de familias y presencia en decenas de ciudades."
        />
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          {impactStats.map((stat) => (
            <article class="premium-card p-5" data-reveal>
              <p class="text-4xl font-bold tracking-tight text-navy">{stat.value}</p>
              <p class="mt-2 text-sm leading-6 text-muted">{stat.label}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell py-16">
    <SectionHeading
      eyebrow="Comunidad en acción"
      title="Historias y publicaciones que muestran a la comunidad aprendiendo, compartiendo y celebrando."
      description="La comunidad vive en cada publicación, evento y momento compartido entre familias, aliados y voluntarios."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {facebookHighlights.map((item, index) => (
        <article class="premium-card overflow-hidden" data-reveal>
          <div class="media-frame h-56 rounded-b-none border-0">
            <img src={item.image} alt={item.title} loading="lazy" />
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(16,35,62,0.02)_0%,rgba(16,35,62,0.48)_100%)]"></div>
            <div class="absolute inset-x-6 bottom-5 flex items-end">
            <span class="rounded-full bg-white/90 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-navy">
              {item.type}
            </span>
          </div>
          </div>
          <div class="p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">Facebook</p>
            <h3 class="mt-2 font-display text-2xl text-ink">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted">{item.description}</p>
            <p class="mt-4 text-sm font-medium text-navy">
              {index === 0 ? 'Encuentros familiares y celebraciones' : 'Aprendizaje compartido y acompañamiento'}
            </p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell py-16">
    <div class="section-band section-band-warm grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center" data-reveal>
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-navy">Donar</p>
        <h2 class="mt-3 font-display text-4xl tracking-tight text-ink">
          Su apoyo mantiene viva nuestra misión.
        </h2>
        <p class="mt-4 text-sm leading-7 text-muted">
          Hacemos todo lo posible por proporcionar recursos valiosos a nuestras comunidades y las donaciones nos ayudan a seguir adelante con esa misión.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          {donationHighlights.map((item) => (
            <article class="premium-card rounded-[1.5rem] bg-white/80 p-4 ring-1 ring-white/70" data-reveal>
              <p class="text-sm leading-6 text-muted">{item}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="flex flex-col gap-3">
        <Button href="/donate">Apoya la misión</Button>
        <Button href="/impact" variant="secondary">Ver el impacto</Button>
      </div>
    </div>
  </section>

  <section class="site-shell py-16">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <SectionHeading
          eyebrow="Recursos"
          title="Recursos para ayudar a nuestras familias a lograr más."
          description="Categorías, materiales y notas de reunión para acercar información clara y útil a las familias."
        />
        <div class="mt-8">
          <Button href="/resources" variant="secondary">Explorar recursos</Button>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {resourceTopics.map((topic) => (
          <article class="premium-card p-5" data-reveal>
            <span class="soft-icon-chip">
              <Icon name="book" class="h-5 w-5" />
            </span>
            <p class="mt-4 text-sm font-semibold uppercase tracking-[0.2em] text-gold">{topic.title}</p>
            <p class="mt-3 text-sm leading-7 text-muted">{topic.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell pb-16 pt-8">
    <div class="section-band section-band-navy grid gap-8 px-8 py-10 text-white lg:grid-cols-[1.15fr_0.85fr] lg:items-center" data-reveal>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/70">Contacto</p>
        <h2 class="mt-3 font-display text-4xl tracking-tight">
          Estamos felices de conectar con ustedes.
        </h2>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-white/80">
          Háganos saber cómo podemos ayudarle o cómo le gustaría participar.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        <Button href="/contact" variant="secondary">Escribir mensaje</Button>
        <Button href="/about" variant="secondary">Conocer la fundación</Button>
      </div>
    </div>
  </section>
</BaseLayout>
