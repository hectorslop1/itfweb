---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { impactMetrics, partners, testimonials } from '../data/site';
---

<BaseLayout
  title="Impact | Ives Torres Foundation"
  description="Historias, resultados y colaboraciones que reflejan el impacto de la fundacion."
>
  <PageHero
    eyebrow="Impacto"
    title="Más oportunidades de inclusión que ayudan a cambiar vidas."
    description="Una comunidad amplia, testimonios reales y aliados que fortalecen la participación de las familias."
    imageSrc="/images/impact/impact-community.jpg"
    imageAlt="Participantes de la comunidad de ITF"
  />

  <section class="site-shell py-12">
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {impactMetrics.map((metric) => (
        <article class="premium-card p-6" data-reveal>
          <p class="text-4xl font-bold tracking-tight text-navy">{metric.value}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{metric.label}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell py-6">
    <SectionHeading
      eyebrow="Voces de la comunidad"
      title="Las historias humanas revelan lo que significa sentirse acompañado."
      description="Estos testimonios hablan de educación, esperanza y apoyo real para las familias."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {testimonials.map((testimonial) => (
        <article class="premium-card p-6" data-reveal>
          <p class="text-lg leading-8 text-ink">"{testimonial.quote}"</p>
          <p class="mt-4 text-sm font-semibold text-navy">{testimonial.name}</p>
          <p class="text-sm text-muted">{testimonial.role}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell py-6">
    <SectionHeading
      eyebrow="Alianzas"
      title="La comunidad crece cuando se tejen puentes entre familias y organizaciones."
      description="Las alianzas de ITF ayudan a extender recursos, confianza y oportunidades de apoyo."
    />
    <div class="mt-8 flex flex-wrap gap-3">
      {partners.map((partner) => (
        <span class="rounded-full border border-line bg-white px-4 py-2 text-sm font-medium text-muted shadow-sm" data-reveal>
          {partner}
        </span>
      ))}
    </div>
  </section>

  <section class="site-shell pb-16 pt-12">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Tu apoyo tambien forma parte del impacto.</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Donantes, voluntarios y aliados hacen posible que más familias encuentren acompañamiento, educación y recursos útiles.
      </p>
      <div class="mt-6">
        <Button href="/donate" variant="secondary">Ver como apoyar</Button>
      </div>
    </div>
  </section>
</BaseLayout>
