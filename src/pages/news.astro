---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { featuredNews } from '../data/news';
---

<BaseLayout
  title="News | Ives Torres Foundation"
  description="Read placeholder news and community updates."
>
  <PageHero
    eyebrow="News"
    title="News and stories that keep the community informed."
    description="This page uses mock updates for the first version so the layout is ready for future posts."
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-5 md:grid-cols-2">
      {featuredNews.map((item) => (
        <article class="rounded-[1.75rem] bg-white p-6 shadow-soft ring-1 ring-line">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{item.date}</p>
          <h2 class="mt-3 font-display text-2xl text-ink">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Update format"
      title="Short, clear stories will be easier for visitors to scan."
      description="A later CMS version can add categories, featured posts, and article pages."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="rounded-[1.5rem] bg-panel p-6">
        <h2 class="font-display text-xl text-ink">Announcements</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Important updates and schedule changes.</p>
      </article>
      <article class="rounded-[1.5rem] bg-white p-6 shadow-soft ring-1 ring-line">
        <h2 class="font-display text-xl text-ink">Stories</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Community-centered stories and milestones.</p>
      </article>
      <article class="rounded-[1.5rem] bg-panel p-6">
        <h2 class="font-display text-xl text-ink">Community updates</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Friendly summaries families can share and revisit.</p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Need the latest info sooner?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        The contact page can route questions about events, programs, or community announcements.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Contact us</Button>
      </div>
    </div>
  </section>
</BaseLayout>
