---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { featuredPrograms } from '../data/programs';
---

<BaseLayout
  title="Programs | Ives Torres Foundation"
  description="Explore the foundation's core programs and support areas."
>
  <PageHero
    eyebrow="Programs"
    title="Programs designed to guide, connect, and strengthen families."
    description="This page introduces the core program areas with placeholder content and a consistent card layout."
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-5 lg:grid-cols-3">
      {featuredPrograms.map((program) => (
        <article class="rounded-[1.75rem] bg-white p-6 shadow-soft ring-1 ring-line">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{program.label}</p>
          <h2 class="mt-3 font-display text-2xl text-ink">{program.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{program.description}</p>
          <p class="mt-5 text-sm font-medium text-navy">{program.audience}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Program model"
      title="A simple structure that can grow into CMS-managed program pages."
      description="For now, the focus is on clear program discovery and a warm visual hierarchy."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <article class="rounded-[1.5rem] border border-white/80 bg-panel p-6">
        <h2 class="font-display text-xl text-ink">What families can expect</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Practical guidance, welcoming spaces, bilingual communication, and next-step support.
        </p>
      </article>
      <article class="rounded-[1.5rem] border border-white/80 bg-white p-6 shadow-soft">
        <h2 class="font-display text-xl text-ink">What comes later</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Program detail pages, CMS editing, featured content, and stronger calls to action.
        </p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Need help choosing a starting point?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        The contact page can help families reach the right program or support route.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Contact support</Button>
      </div>
    </div>
  </section>
</BaseLayout>
