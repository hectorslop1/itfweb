---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { donationAmounts, donationHighlights, donationMethods, partners } from '../data/site';
---

<BaseLayout
  title="Donate | Ives Torres Foundation"
  description="Apoya la misión de Ives Torres Foundation y ayuda a sostener recursos valiosos para la comunidad."
>
  <PageHero
    eyebrow="Apoya"
    title="Tu apoyo mantiene viva nuestra misión."
    description="Hacemos todo lo posible por proporcionar recursos valiosos a nuestras comunidades y las donaciones nos dan la capacidad de seguir adelante con ese trabajo."
    imageSrc="/images/donate/donate-support.jpg"
    imageAlt="Comunidad y apoyo en una actividad de la fundación"
  />

  <section class="site-shell py-12">
    <div class="grid gap-5 md:grid-cols-3">
      {donationHighlights.map((item) => (
        <article class="premium-card p-6" data-reveal>
          <p class="text-sm leading-7 text-muted">{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell py-6">
    <div class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <article class="section-band section-band-warm overflow-hidden" data-reveal>
        <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div>
            <div class="eyebrow-chip">Apoya la misión</div>
            <h2 class="mt-5 font-display text-[clamp(2rem,3.8vw,3.4rem)] leading-[1.06] tracking-tight text-ink">
              Tu apoyo ayuda a sostener recursos, eventos y comunidad.
            </h2>
            <p class="mt-4 max-w-xl text-base leading-7 text-muted">
              Los datos finales de PayPal y Zelle se confirmarán con la fundación antes del lanzamiento.
            </p>
            <div class="mt-6 grid gap-3 sm:grid-cols-3">
              {donationAmounts.map((item) => (
                <article class="premium-card rounded-[1.5rem] bg-white/88 p-5 ring-1 ring-white/70" data-reveal>
                  <p class="text-3xl font-bold tracking-tight text-navy">{item.amount}</p>
                  <p class="mt-3 text-sm leading-6 text-muted">{item.label}</p>
                </article>
              ))}
            </div>
          </div>
          <div class="media-frame min-h-[20rem] lg:min-h-[24rem]">
            <img
              src="/images/donate/donate-support.jpg"
              alt="Familias y aliados en una actividad de apoyo comunitario de Ives Torres Foundation"
              class="h-full w-full object-cover object-center"
              loading="lazy"
            />
          </div>
        </div>
      </article>

      <article class="premium-card p-6" data-reveal>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">Opciones de apoyo</p>
        <h2 class="mt-3 font-display text-3xl text-ink">Elige la forma de donar que mejor se adapte a ti.</h2>
        <p class="mt-3 text-sm leading-7 text-muted">
          Hemos preparado una experiencia de donación clara para que familias, aliados y comunidad puedan apoyar con confianza.
        </p>
        <div class="mt-6 space-y-4">
          {donationMethods.map((method, index) => (
            <article class="rounded-[1.4rem] border border-line/80 bg-white/88 p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-[0_14px_28px_rgba(16,35,62,0.1)]">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="tag-badge">{index === 0 ? 'Principal' : 'Secundaria'}</div>
                  <h3 class="mt-3 font-display text-2xl text-ink">{method.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-muted">{method.description}</p>
                </div>
                <span class="icon-chip" aria-hidden="true">
                  {index === 0 ? '$' : 'Z'}
                </span>
              </div>
              <div class="mt-5">
                <Button href="/contact" variant={index === 0 ? 'primary' : 'secondary'} class="w-full">
                  {index === 0 ? 'Donar con PayPal' : 'Donar con Zelle'}
                </Button>
              </div>
            </article>
          ))}
        </div>
      </article>
    </div>
  </section>

  <section class="site-shell py-6">
    <div class="grid gap-8 rounded-[2.25rem] bg-white/80 p-8 shadow-soft ring-1 ring-white/70 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div>
        <SectionHeading
          eyebrow="Por qué donar"
          title="Cada aporte ayuda a perseguir la misión y sostener el impacto comunitario."
          description="Tu apoyo ayuda a sostener el mensaje de apoyo, inclusión y agradecimiento que la fundación comparte con su comunidad."
        />
      </div>
      <div class="premium-card p-6" data-reveal>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">Aliados públicos</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {partners.slice(0, 6).map((partner) => (
            <span class="tag-badge !border-line !bg-panel">{partner}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell pb-16 pt-12">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.92fr]">
      <div class="section-band section-band-navy text-white" data-reveal>
        <h2 class="font-display text-3xl tracking-tight">¿Tienes preguntas sobre cómo apoyar?</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
          Estamos disponibles para orientar a donantes, familias y aliados que quieran contribuir al trabajo de la fundación.
        </p>
        <div class="mt-6">
          <Button href="/contact" variant="secondary">Hablar con el equipo</Button>
        </div>
      </div>

      <div class="space-y-4" data-reveal>
        <details class="faq-item" open>
          <summary class="faq-summary">
            <span>¿Cómo puedo donar?</span>
            <span class="faq-symbol" aria-hidden="true">+</span>
          </summary>
          <div class="px-5 pb-5 text-sm leading-7 text-muted">
            Puedes explorar las opciones de PayPal y Zelle en esta página y escribir al equipo para recibir orientación adicional.
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-summary">
            <span>¿Puedo donar por Zelle?</span>
            <span class="faq-symbol" aria-hidden="true">+</span>
          </summary>
          <div class="px-5 pb-5 text-sm leading-7 text-muted">
            Sí. La opción de Zelle se mostrará como alternativa de apoyo y los datos finales se confirmarán con la fundación antes del lanzamiento.
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-summary">
            <span>¿A quién puedo contactar si tengo preguntas?</span>
            <span class="faq-symbol" aria-hidden="true">+</span>
          </summary>
          <div class="px-5 pb-5 text-sm leading-7 text-muted">
            Puedes escribir a Info@IvesTorres.org o comunicarte al (951) 737-0951 para recibir orientación.
          </div>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>
