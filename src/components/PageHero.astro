---
const { eyebrow, title, description } = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
};
---

<section class="mx-auto max-w-7xl px-4 pt-14 sm:px-6 lg:px-8 lg:pt-20">
  <div class="overflow-hidden rounded-[2rem] border border-white/80 bg-white shadow-soft">
    <div class="grid gap-8 bg-[radial-gradient(circle_at_top_left,rgba(214,168,63,0.14),transparent_38%),radial-gradient(circle_at_top_right,rgba(22,53,93,0.12),transparent_34%)] px-6 py-10 sm:px-8 lg:grid-cols-[1fr_auto] lg:items-end lg:px-10 lg:py-12">
      <div class="max-w-3xl">
        {eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold">
            {eyebrow}
          </p>
        )}
        <h1 class="mt-3 font-display text-4xl tracking-tight text-ink sm:text-5xl">
          {title}
        </h1>
        {description && <p class="mt-4 max-w-2xl text-base leading-7 text-muted">{description}</p>}
      </div>
      <div class="h-16 w-16 rounded-3xl bg-navy/10"></div>
    </div>
  </div>
</section>
