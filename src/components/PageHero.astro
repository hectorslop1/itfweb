---
import Icon from './Icon.astro';

const { eyebrow, title, description, imageSrc, imageAlt = '' } = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
  imagePosition?: string;
  imageNote?: string;
  imageNoteIcon?: 'mail' | 'phone' | 'map' | 'heart' | 'calendar' | 'book' | 'users' | 'spark';
};

const { imagePosition = 'center', imageNote, imageNoteIcon = 'spark' } = Astro.props as {
  imagePosition?: string;
  imageNote?: string;
  imageNoteIcon?: 'mail' | 'phone' | 'map' | 'heart' | 'calendar' | 'book' | 'users' | 'spark';
};
---

<section class="hero-shell pt-10 lg:pt-14" data-reveal-group>
  <div class="section-band page-hero-card section-band-soft overflow-hidden lg:min-h-[37rem]" data-reveal style="--reveal-delay: 0ms;">
    <div class="grid gap-6 bg-[radial-gradient(circle_at_top_left,rgba(214,168,63,0.14),transparent_38%),radial-gradient(circle_at_top_right,rgba(22,53,93,0.12),transparent_34%)] lg:min-h-[33rem] lg:grid-cols-[minmax(0,1fr)_38rem] lg:items-center xl:grid-cols-[minmax(0,1fr)_40rem]">
      <div class="max-w-[34rem] lg:flex lg:min-h-[29rem] lg:flex-col lg:justify-center">
        {eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold" data-reveal style="--reveal-delay: 0ms;">
            {eyebrow}
          </p>
        )}
        <h1 class="mt-3 max-w-[33rem] font-display text-[clamp(2.2rem,3.15vw,3.5rem)] leading-[1.06] tracking-tight text-ink" data-reveal style="--reveal-delay: 70ms; text-wrap: balance;">
          {title}
        </h1>
        {description && <p class="mt-4 max-w-[31rem] text-[0.98rem] leading-7 text-muted sm:text-[1.01rem]" data-reveal style="--reveal-delay: 140ms;">{description}</p>}
      </div>
      {imageSrc ? (
        <div class="media-frame min-h-[17rem] lg:h-[31rem] lg:min-h-0" data-reveal style="--reveal-delay: 120ms;">
          <img src={imageSrc} alt={imageAlt} class="h-full w-full object-cover" style={`object-position: ${imagePosition};`} loading="lazy" />
          {imageNote && (
            <div class="image-note">
              <div class="flex items-center gap-3">
                <span class="soft-icon-chip h-10 w-10 border-white/20 text-white" style="background-color: rgba(255,255,255,0.16);">
                  <Icon name={imageNoteIcon} class="h-4 w-4" />
                </span>
                <p class="text-sm font-medium leading-6 text-white">{imageNote}</p>
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class="h-16 w-16 rounded-3xl bg-navy/10"></div>
      )}
    </div>
  </div>
</section>
