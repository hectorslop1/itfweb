---
import Icon from './Icon.astro';

const { eyebrow, title, description, imageSrc, imageAlt = '' } = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
  imagePosition?: string;
  imageNote?: string;
  imageNoteIcon?: 'mail' | 'phone' | 'map' | 'heart' | 'calendar' | 'book' | 'users' | 'spark';
};

const { imagePosition = 'center', imageNote, imageNoteIcon = 'spark' } = Astro.props as {
  imagePosition?: string;
  imageNote?: string;
  imageNoteIcon?: 'mail' | 'phone' | 'map' | 'heart' | 'calendar' | 'book' | 'users' | 'spark';
};
---

<section class="hero-shell pt-14 lg:pt-20" data-reveal-group>
  <div class="section-band section-band-soft overflow-hidden" data-reveal style="--reveal-delay: 0ms;">
    <div class="grid gap-8 bg-[radial-gradient(circle_at_top_left,rgba(214,168,63,0.14),transparent_38%),radial-gradient(circle_at_top_right,rgba(22,53,93,0.12),transparent_34%)] lg:grid-cols-[1.02fr_0.98fr] lg:items-center xl:gap-12">
      <div class="max-w-4xl">
        {eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold" data-reveal style="--reveal-delay: 0ms;">
            {eyebrow}
          </p>
        )}
        <h1 class="mt-3 max-w-4xl font-display text-[clamp(2.5rem,4.4vw,4.5rem)] leading-[1.05] tracking-tight text-ink" data-reveal style="--reveal-delay: 70ms;">
          {title}
        </h1>
        {description && <p class="mt-4 max-w-2xl text-base leading-7 text-muted sm:text-[1.05rem]" data-reveal style="--reveal-delay: 140ms;">{description}</p>}
      </div>
      {imageSrc ? (
        <div class="media-frame min-h-[18rem] lg:min-h-[22rem]" data-reveal style="--reveal-delay: 120ms;">
          <img src={imageSrc} alt={imageAlt} class="h-full w-full object-cover" style={`object-position: ${imagePosition};`} loading="lazy" />
          {imageNote && (
            <div class="image-note">
              <div class="flex items-center gap-3">
                <span class="soft-icon-chip h-10 w-10 border-white/20 bg-white/12 text-white">
                  <Icon name={imageNoteIcon} class="h-4 w-4" />
                </span>
                <p class="text-sm leading-6 text-white/92">{imageNote}</p>
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class="h-16 w-16 rounded-3xl bg-navy/10"></div>
      )}
    </div>
  </div>
</section>
