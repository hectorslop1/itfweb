---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { upcomingEvents } from '../data/events';
---

<BaseLayout
  title="Events | Ives Torres Foundation"
  description="Conoce proximos eventos, talleres y encuentros comunitarios."
>
  <PageHero
    eyebrow="Eventos"
    title="Encuentros pensados para aprender, compartir y sentirse acompanados."
    description="Los eventos de la fundacion acercan recursos, conversacion y comunidad a familias que necesitan orientacion y conexion."
    imageSrc="/images/community-event.svg"
    imageAlt="Ilustracion de evento comunitario"
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-4">
      {upcomingEvents.map((event) => (
        <article class="shell-card flex flex-col gap-5 p-5 sm:flex-row sm:items-center">
          <div class="grid h-20 w-20 shrink-0 place-items-center rounded-2xl bg-panel text-center">
            <span class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{event.date}</span>
          </div>
          <div class="min-w-0 grow">
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="font-display text-2xl text-ink">{event.title}</h2>
              <span class="rounded-full bg-sky/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-navy">
                {event.location}
              </span>
              {event.time && (
                <span class="rounded-full bg-gold/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-navy">
                  {event.time}
                </span>
              )}
            </div>
            <p class="mt-2 text-sm leading-7 text-muted">{event.details}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Experiencia"
      title="Mas que fechas, los eventos son una puerta de entrada a la comunidad."
      description="Cada encuentro busca que las familias se lleven informacion util y la tranquilidad de saber que hay apoyo cerca."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="shell-card p-6">
        <h2 class="font-display text-xl text-ink">Talleres</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Espacios de aprendizaje con explicaciones claras y tiempo para preguntas reales.</p>
      </article>
      <article class="shell-card p-6">
        <h2 class="font-display text-xl text-ink">Convivencia</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Encuentros que fortalecen relaciones, confianza y apoyo entre familias.</p>
      </article>
      <article class="shell-card p-6">
        <h2 class="font-display text-xl text-ink">Recursos</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Oportunidades para conocer aliados, materiales utiles y servicios disponibles.</p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 pt-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Quieres saber cual evento es mejor para tu familia?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Podemos ayudarte a encontrar un taller, encuentro o actividad que responda a tus intereses y necesidades.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Pedir informacion</Button>
      </div>
    </div>
  </section>
</BaseLayout>
