---
const { eyebrow, title, description, imageSrc, imageAlt = '' } = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
};
---

<section class="hero-shell pt-14 lg:pt-20">
  <div class="section-band section-band-soft overflow-hidden" data-reveal>
    <div class="grid gap-8 bg-[radial-gradient(circle_at_top_left,rgba(214,168,63,0.14),transparent_38%),radial-gradient(circle_at_top_right,rgba(22,53,93,0.12),transparent_34%)] lg:grid-cols-[1fr_26rem] lg:items-end xl:grid-cols-[1fr_29rem]">
      <div class="max-w-4xl">
        {eyebrow && (
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold">
            {eyebrow}
          </p>
        )}
        <h1 class="mt-3 max-w-4xl font-display text-[clamp(2.5rem,4.4vw,4.5rem)] leading-[1.05] tracking-tight text-ink">
          {title}
        </h1>
        {description && <p class="mt-4 max-w-2xl text-base leading-7 text-muted sm:text-[1.05rem]">{description}</p>}
      </div>
      {imageSrc ? (
        <div class="media-frame min-h-[18rem] lg:min-h-[22rem]">
          <img src={imageSrc} alt={imageAlt} class="h-full w-full object-cover object-center" loading="lazy" />
        </div>
      ) : (
        <div class="h-16 w-16 rounded-3xl bg-navy/10"></div>
      )}
    </div>
  </div>
</section>
