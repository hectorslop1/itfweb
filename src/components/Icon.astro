---
const {
  name,
  class: className = 'h-5 w-5',
  title,
} = Astro.props as {
  name:
    | 'mail'
    | 'phone'
    | 'map'
    | 'heart'
    | 'calendar'
    | 'book'
    | 'users'
    | 'facebook'
    | 'instagram'
    | 'youtube'
    | 'linkedin'
    | 'tiktok'
    | 'menu'
    | 'spark'
    | 'arrow-right';
  class?: string;
  title?: string;
};

const icons: Record<string, string> = {
