---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import ContactFormDemo from '../components/ContactFormDemo.astro';
import Icon from '../components/Icon.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { contactPoints, contactReasons } from '../data/site';
---

<BaseLayout
  title="Contacto | Ives Torres Foundation"
  description="Contacta a Ives Torres Foundation para recibir apoyo, colaborar o hacer una consulta."
>
  <PageHero
    eyebrow="Contacto"
    title="Estamos aquí para escuchar, orientar y conectar a tu familia con apoyo."
    description="Siempre estamos felices de conectarnos. Háganos saber cómo podemos ayudarle o cómo le gustaría participar."
    imageSrc="/images/programs/programs-community.jpg"
    imageAlt="Familias en una actividad comunitaria de la fundación"
    imagePosition="center 38%"
    imageNote="Escríbenos a Info@IvesTorres.org o llámanos al (951) 737-0951."
    imageNoteIcon="mail"
  />

  <section class="site-shell pb-6 pt-8">
      <div class="grid gap-5 md:grid-cols-3" data-reveal-group>
        {contactPoints.map((point) => (
          <article class="contact-card" data-reveal>
            <div class="flex items-start gap-5">
              <span class="icon-chip h-14 w-14 rounded-[1.4rem]" aria-hidden="true">
                <Icon
                  name={point.label === 'Email' ? 'mail' : point.label === 'Teléfono' ? 'phone' : 'map'}
                  class="h-5 w-5"
                />
              </span>
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{point.label}</p>
                <p class="mt-2 text-base font-medium leading-7 text-ink">{point.value}</p>
                <p class="mt-1 text-sm leading-6 text-muted">
                  {point.label === 'Email'
                    ? 'Escríbenos para orientación y seguimiento.'
                    : point.label === 'Teléfono'
                      ? 'Atención directa para preguntas y apoyo.'
                      : 'Presencia comunitaria en regiones clave.'}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>
  </section>

  <section class="site-shell py-8">
    <SectionHeading
      eyebrow="Cómo podemos ayudarte"
      title="Elige el motivo de tu mensaje y cuéntanos qué necesitas."
      description="También puedes solicitar una cita y compartir desde aquí la necesidad principal de tu familia."
    />
    <div class="mt-8 flex flex-wrap gap-3">
      {contactReasons.map((reason) => (
        <span class="tag-badge !border-line !bg-white !px-4 !py-2 !text-sm normal-case tracking-normal text-muted">
          {reason}
        </span>
      ))}
    </div>
  </section>

  <section class="site-shell pb-16 pt-10">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <ContactFormDemo />
      <div class="space-y-5">
        <article class="feature-card" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">Apoyo familiar</p>
          <h2 class="mt-3 font-display text-2xl text-ink">Una conversación puede ser el primer paso.</h2>
          <p class="mt-3 text-sm leading-7 text-muted">
            Si no sabes por dónde empezar, podemos orientarte hacia recursos, programas o eventos que se alineen con tu situación.
          </p>
        </article>
        <article class="premium-card p-6" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">Citas y contacto directo</p>
          <p class="mt-3 text-sm leading-7 text-muted">
            También puedes escribirnos o llamarnos directamente para pedir información, apoyo o una cita.
          </p>
          <div class="mt-5">
            <Button href="mailto:Info@IvesTorres.org" variant="secondary">Escribir por email</Button>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
