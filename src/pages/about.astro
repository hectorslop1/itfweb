---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { aboutSections, teamMembers, values } from '../data/site';
---

<BaseLayout
  title="About | Ives Torres Foundation"
  description="Learn about the foundation story, mission, vision, and the people behind the work."
>
  <PageHero
    eyebrow="About"
    title="A foundation built to help families feel informed and supported."
    description="This page gives visitors a clear introduction to the foundation, its purpose, and the values shaping the new site."
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-5 md:grid-cols-3">
      {aboutSections.map((item) => (
        <article class="rounded-[1.75rem] border border-white/80 bg-white p-6 shadow-soft">
          <h2 class="font-display text-2xl text-ink">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Values"
      title="The foundation's tone is guided by trust, warmth, and clarity."
      description="These values influence the copy, layout, and content hierarchy across the site."
    />
    <div class="mt-8 flex flex-wrap gap-3">
      {values.map((value) => (
        <span class="rounded-full border border-line bg-white px-4 py-2 text-sm font-medium text-muted shadow-sm">
          {value}
        </span>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="People"
      title="The work is rooted in people, partnerships, and community trust."
      description="These placeholder bios keep the page grounded while the real leadership and team content is prepared."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {teamMembers.map((member) => (
        <article class="rounded-[1.75rem] bg-white p-6 shadow-soft ring-1 ring-line">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{member.role}</p>
          <h2 class="mt-3 font-display text-2xl text-ink">{member.name}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{member.bio}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Want to learn more about the foundation?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        The next build steps will expand this page with richer story content, leadership, and mission details.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Contact us</Button>
      </div>
    </div>
  </section>
</BaseLayout>
