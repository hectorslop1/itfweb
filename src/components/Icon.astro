  book: '<path d="M6.5 4.75h9.25A2.25 2.25 0 0 1 18 7v12.25H8.75A2.25 2.25 0 0 0 6.5 21.5Z"/><path d="M6.5 4.75A2.25 2.25 0 0 0 4.25 7v10.5a2.25 2.25 0 0 0 2.25 2.25H18" fill="none"/><path d="M8.75 8.5h5.5M8.75 11.5h5.5" fill="none" stroke-linecap="round"/>',
  users: '<path d="M16.5 19.25v-.75a3.25 3.25 0 0 0-3.25-3.25H8.75A3.25 3.25 0 0 0 5.5 18.5v.75"/><circle cx="11" cy="9" r="3.25"/><path d="M18.5 15.75v-.25A2.5 2.5 0 0 0 16 13M16 6.75a2.75 2.75 0 0 1 0 5.5" fill="none" stroke-linecap="round"/>',
