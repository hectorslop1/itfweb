---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { featuredNews } from '../data/news';
---

<BaseLayout
  title="News | Ives Torres Foundation"
  description="Noticias, historias y actualizaciones de la comunidad de Ives Torres Foundation."
>
  <PageHero
    eyebrow="Noticias"
    title="Historias y actualizaciones que ayudan a seguir de cerca a la comunidad."
    description="Historias, apoyos y colaboraciones que muestran el movimiento diario de la fundación."
    imageSrc="/images/community/community-cabe.jpeg"
    imageAlt="Participantes en una actividad comunitaria"
  />

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {featuredNews.map((item) => (
        <article class="premium-card overflow-hidden" data-reveal>
          <div class="media-frame h-48 rounded-b-none border-0">
            <img src={item.image} alt={item.title} loading="lazy" />
          </div>
          <div class="p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{item.date}</p>
          <h2 class="mt-3 font-display text-2xl text-ink">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Lo que compartimos"
      title="Noticias que ayudan a entender lo que está pasando y por qué importa."
      description="La mezcla de historias, agradecimientos y colaboraciones permite seguir el pulso comunitario de ITF."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="shell-panel p-6" data-reveal>
        <h2 class="font-display text-xl text-ink">Anuncios</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Información sobre eventos, fechas y oportunidades para participar.</p>
      </article>
      <article class="premium-card p-6" data-reveal>
        <h2 class="font-display text-xl text-ink">Historias</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Momentos que muestran la fuerza de las familias y la comunidad.</p>
      </article>
      <article class="shell-panel p-6" data-reveal>
        <h2 class="font-display text-xl text-ink">Aliados</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Colaboraciones y recursos que amplían el alcance de la fundación.</p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 pt-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] bg-navy p-8 text-white shadow-soft">
      <h2 class="font-display text-3xl tracking-tight">Quieres mantenerte cerca de las novedades?</h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-white/80">
        Estamos aquí para compartir información sobre programas, eventos y maneras de apoyar a la comunidad.
      </p>
      <div class="mt-6">
        <Button href="/contact" variant="secondary">Hablar con nosotros</Button>
      </div>
    </div>
  </section>
</BaseLayout>
